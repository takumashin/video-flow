# 火山方舟 API Key（必填）
# 在 https://console.volcengine.com/ark 获取
ARK_API_KEY=your_ark_api_key_here

# 默认模型 Model ID（可选，节点未选择模型时使用）
# 官方 Model ID 示例：
#   doubao-seedance-2-0-260128        Seedance 2.0（多模态参考）
#   doubao-seedance-2-0-fast-260128   Seedance 2.0 Fast
#   doubao-seedance-1-5-pro-251215     Seedance 1.5 Pro（推荐，支持音频）
#   doubao-seedance-1-0-pro-250528     Seedance 1.0 Pro
#   doubao-seedance-1-0-pro-fast-251015 Seedance 1.0 Pro Fast
# 也可填写推理接入点 Endpoint ID（ep- 开头）
# 文档：https://www.volcengine.com/docs/82379/1520757
ARK_MODEL=doubao-seedance-1-5-pro-251215

# API 基础地址（可选，默认北京区域）
ARK_BASE_URL=https://ark.cn-beijing.volces.com

# 火山费用中心 IAM 访问密钥（可选，用于顶栏显示账户余额）
# 与 ARK_API_KEY 不同：在 https://console.volcengine.com/iam/keymanage 创建
# 需具备费用中心「查询余额」相关权限（如 billing:QueryBalanceAcct）
VOLC_ACCESS_KEY_ID=your_iam_access_key_id
VOLC_SECRET_ACCESS_KEY=your_iam_secret_access_key
