# 火山方舟 API Key（必填）
# 在 https://console.volcengine.com/ark 获取
ARK_API_KEY=your_ark_api_key_here

# 默认模型 Model ID（可选，节点未选择模型时使用）
# 官方 Model ID 示例：
#   doubao-seedance-2-0-260128        Seedance 2.0（多模态参考）
#   doubao-seedance-2-0-fast-260128   Seedance 2.0 Fast
#   doubao-seedance-1-5-pro-251215     Seedance 1.5 Pro（推荐，支持音频）
#   doubao-seedance-1-0-pro-250528     Seedance 1.0 Pro
#   doubao-seedance-1-0-pro-fast-251015 Seedance 1.0 Pro Fast
# 也可填写推理接入点 Endpoint ID（ep- 开头）
# 文档：https://www.volcengine.com/docs/82379/1520757
ARK_MODEL=doubao-seedance-1-5-pro-251215

# API 基础地址（可选，默认北京区域）
ARK_BASE_URL=https://ark.cn-beijing.volces.com

# 用户初始点数（可选，默认 5000；新用户注册时赠送）
# USER_INITIAL_CREDITS=5000

# 管理员邮箱（可选，逗号分隔；配置后可访问 /admin/credits 管理用户点数）
# ADMIN_EMAILS=admin@example.com,ops@example.com

# 工作流实时协作 WebSocket（开发环境默认 ws://localhost:3001）
# NEXT_PUBLIC_WORKFLOW_WS_URL=ws://localhost:3001
# WORKFLOW_WS_PORT=3001

# Seedance 全系统并发上限（可选，默认 10，参考火山方舟 Pro/2.0 在线推理并发）
# 超过上限的任务会在后台排队（waiting），有空槽后再提交火山 API
# SEEDANCE_MAX_CONCURRENCY=10

# 火山费用中心 IAM 访问密钥（可选，用于顶栏显示账户余额）
# 与 ARK_API_KEY 不同：在 https://console.volcengine.com/iam/keymanage 创建
# 需具备费用中心「查询余额」相关权限（如 billing:QueryBalanceAcct）
VOLC_ACCESS_KEY_ID=your_iam_access_key_id
VOLC_SECRET_ACCESS_KEY=your_iam_secret_access_key

# PostgreSQL 数据库（必填）
#
# Homebrew 本地部署（推荐，先运行 pnpm db:setup）：
#   brew install postgresql@15 && brew services start postgresql@15
#   DATABASE_URL=postgresql://你的用户名@localhost:5432/seedance_studio
#
# Docker 部署（可选，运行 pnpm db:docker:setup）：
#   DATABASE_URL=postgresql://seedance:seedance@localhost:5433/seedance_studio
DATABASE_URL=postgresql://isaacxin@localhost:5432/seedance_studio

# Auth.js 密钥（必填）
# 生成方式：openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here

# 应用 URL（生产环境必填；本地 OAuth 调试需用 ngrok 地址）
AUTH_URL=http://localhost:3000

# 邮件 SMTP（可选；用于邮箱验证、密码重置、工作空间邀请）
# 未配置时开发环境会在服务端日志打印邮件内容
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Seedance Studio <noreply@example.com>"

# 微信开放平台 - 网站应用（可选）
# 1. 在 https://open.weixin.qq.com 创建「网站应用」（不是公众号/小程序）
# 2. 授权回调域填你的域名（仅域名，不要带 http:// 或路径），例如：studio.example.com
# 3. 微信不支持 localhost；本地调试请用 ngrok 等工具暴露 HTTPS 公网地址，并同步修改 AUTH_URL
# 4. 回调地址：{AUTH_URL}/api/auth/callback/wechat
AUTH_WECHAT_APP_ID=
AUTH_WECHAT_APP_SECRET=

# 飞书开放平台 - 网页应用（可选）
# 在开发者后台 -> 开发配置 -> 安全设置 -> 重定向 URL 添加：{AUTH_URL}/api/auth/callback/feishu
# 国际版 Lark 请设置 AUTH_FEISHU_DOMAIN=lark
# scope 留空即可登录；协作邀请链接只需飞书 OAuth，无需通讯录或发消息权限
AUTH_FEISHU_APP_ID=
AUTH_FEISHU_APP_SECRET=
# AUTH_FEISHU_SCOPE=
# AUTH_FEISHU_DOMAIN=feishu

# 微博开放平台（可选）
AUTH_WEIBO_CLIENT_ID=
AUTH_WEIBO_CLIENT_SECRET=
